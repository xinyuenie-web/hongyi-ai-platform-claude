# ============================================================
# 红艺花木 - Next.js Website
# Multi-stage build with standalone output
# Optimized: package.json copied first for npm ci layer caching
# ============================================================

# --- Stage 1: Install & Build ---
ARG BASE_IMAGE=node:20-alpine
FROM ${BASE_IMAGE} AS builder

WORKDIR /app

# Use China npm mirror for reliability
RUN npm config set registry https://registry.npmmirror.com

# Step 1: Copy ONLY dependency files (cache npm ci when deps don't change)
COPY package.json package-lock.json tsconfig.base.json ./
COPY packages/shared/package.json packages/shared/
COPY apps/website/package.json apps/website/

# Step 2: Install dependencies (this layer is cached if package*.json unchanged)
RUN npm ci --workspace=packages/shared --workspace=apps/website --include-workspace-root

# Step 3: Copy source code (changes frequently, but npm ci is already cached)
COPY packages/shared/ packages/shared/
COPY apps/website/ apps/website/

# Build shared
RUN cd packages/shared && npx tsc

# Build Next.js (standalone mode)
ENV NEXT_TELEMETRY_DISABLED=1
RUN cd apps/website && npx next build

# --- Stage 2: Production Runner ---
ARG BASE_IMAGE=node:20-alpine
FROM ${BASE_IMAGE} AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV HOSTNAME=0.0.0.0
ENV PORT=3000

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# Copy standalone server
COPY --from=builder /app/apps/website/.next/standalone ./

# Copy static assets
COPY --from=builder /app/apps/website/.next/static ./apps/website/.next/static

# Copy public assets
COPY --from=builder /app/apps/website/public ./apps/website/public

USER nextjs

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:3000 || exit 1

CMD ["node", "apps/website/server.js"]
