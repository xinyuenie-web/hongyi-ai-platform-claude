# ============================================================
# 红艺花木 - Express API Server
# Optimized: package.json copied first for npm ci layer caching
# ============================================================

# --- Stage 1: Build ---
ARG BASE_IMAGE=node:20-alpine
FROM ${BASE_IMAGE} AS builder

WORKDIR /app

# Use China npm mirror for reliability
RUN npm config set registry https://registry.npmmirror.com

# Step 1: Copy ONLY dependency files (cache npm ci when deps don't change)
COPY package.json package-lock.json tsconfig.base.json ./
COPY packages/shared/package.json packages/shared/
COPY apps/server/package.json apps/server/

# Step 2: Install dependencies (this layer is cached if package*.json unchanged)
RUN npm ci --workspace=packages/shared --workspace=apps/server --include-workspace-root 2>/dev/null || \
    npm install --workspace=packages/shared --workspace=apps/server --include-workspace-root

# Step 3: Copy source code (changes frequently, but npm ci is already cached)
COPY packages/shared/ packages/shared/
COPY apps/server/ apps/server/

# Build shared package
RUN cd packages/shared && npx tsc || true

# Build server (compile TS)
RUN cd apps/server && npx tsc || true

# --- Stage 2: Production ---
ARG BASE_IMAGE=node:20-alpine
FROM ${BASE_IMAGE} AS runner

WORKDIR /app

ENV NODE_ENV=production

# Use China npm mirror
RUN npm config set registry https://registry.npmmirror.com

# Copy workspace root
COPY package.json package-lock.json tsconfig.base.json ./

# Copy shared built output
COPY --from=builder /app/packages/shared/ packages/shared/

# Copy server source + built
COPY --from=builder /app/apps/server/ apps/server/

# Copy seed data files (CSV)
COPY *.csv ./

# Install production deps only
RUN npm ci --workspace=packages/shared --workspace=apps/server --include-workspace-root --omit=dev 2>/dev/null || \
    npm install --workspace=packages/shared --workspace=apps/server --include-workspace-root --omit=dev

# Install tsx globally for running TypeScript directly
RUN npm install -g tsx

# Create uploads directories
RUN mkdir -p uploads/inquiries uploads/ai-generated

EXPOSE 4000

# Health check
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:4000/api/health || exit 1

CMD ["tsx", "apps/server/src/index.ts"]
