# MongoDB
MONGODB_URI=mongodb://localhost:27017/hongyi

# Redis (optional for P0)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-change-in-production

# Tencent Cloud COS
TENCENT_COS_SECRET_ID=your-cos-secret-id
TENCENT_COS_SECRET_KEY=your-cos-secret-key
TENCENT_COS_BUCKET=hongyi-trees-xxxxxxxxxx
TENCENT_COS_REGION=ap-guangzhou

# Claude API
ANTHROPIC_API_KEY=sk-ant-your-key

# Doubao (豆包) API Keys
DOUBAO_API_KEY=your-doubao-seedream-api-key
DOUBAO_VISION_API_KEY=your-doubao-vision-api-key
# Optional: override default model names
# DOUBAO_SEEDREAM_MODEL=doubao-seedream-5-0-lite-260128
# DOUBAO_VISION_MODEL=doubao-seed-2-0-pro-260215

# WeChat
WECHAT_APPID=your-appid
WECHAT_SECRET=your-secret
WECHAT_TOKEN=your-verify-token

# Server
PORT=4000
NODE_ENV=development

# Website
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=https://www.ai花木.com
